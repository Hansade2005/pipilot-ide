# Anthropic-compatible API (Agent SDK)
ANTHROPIC_BASE_URL=https://the3rdacademy.com/api
ANTHROPIC_API_KEY=sk-praxis-<your-key>

# Backend server port
PORT=3001

# Where the Agent SDK creates project workspaces on disk
# Each project gets its own subdirectory: <WORKSPACES_ROOT>/<projectId>/
# Default: .workspaces/ in the project root
WORKSPACES_ROOT=
